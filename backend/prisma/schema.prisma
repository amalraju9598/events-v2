// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────────────────────

enum UserType {
  super_admin
  user
  client
}

// ─────────────────────────────────────────────────────────
//  Users
// ─────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid()) @db.VarChar(36)
  name                 String    @db.VarChar(255)
  email                String    @unique @db.VarChar(255)
  mobile               String?   @unique @db.VarChar(20)
  password             String    @db.VarChar(255)
  username             String?   @unique @db.VarChar(100)
  user_type            UserType  @default(user)
  profile_pic          String?   @db.Text
  email_verified_at    DateTime?
  phone_verified_at    DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  // Relations
  user_roles  UserRole[]
  event_types EventType[]
  events      Event[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────
//  Roles
// ─────────────────────────────────────────────────────────

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  // Relations
  user_roles       UserRole[]
  role_permissions RolePermission[]

  @@map("roles")
}

// ─────────────────────────────────────────────────────────
//  Permissions
// ─────────────────────────────────────────────────────────

model Permission {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(150)

  // Relations
  role_permissions RolePermission[]

  @@map("permissions")
}

// ─────────────────────────────────────────────────────────
//  Join: Users ↔ Roles
// ─────────────────────────────────────────────────────────

model UserRole {
  user_id String @db.VarChar(36)
  role_id Int

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────
//  Join: Roles ↔ Permissions
// ─────────────────────────────────────────────────────────

model RolePermission {
  role_id       Int
  permission_id Int

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────
//  Event Types
// ─────────────────────────────────────────────────────────

model EventType {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  icon        String?  @db.VarChar(255)
  identifier  String   @db.VarChar(255)
  user_id     String?  @db.VarChar(36)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relation
  user      User?      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  templates Template[]
  events    Event[]

  // Unique constraint
  @@unique([identifier, user_id])
  @@map("event_types")
}

// ─────────────────────────────────────────────────────────
//  Templates & Fields
// ─────────────────────────────────────────────────────────

enum TemplateStatus {
  draft
  active
  disabled
}

enum FieldType {
  text
  image
  date
  long_text
  location
}

model Template {
  id                  String         @id @default(uuid()) @db.VarChar(36)
  event_type_id       String         @db.VarChar(36)
  name                String         @db.VarChar(255)
  slug                String         @unique @db.VarChar(255)
  code                String         @unique @db.VarChar(50)
  price               Decimal        @db.Decimal(10, 2)
  strikethrough_price Decimal?       @db.Decimal(10, 2)
  preview_image       String?        @db.Text
  view_page           String?        @db.VarChar(255)
  status              TemplateStatus @default(draft)
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  // Relations
  event_type      EventType       @relation(fields: [event_type_id], references: [id], onDelete: Cascade)
  template_fields TemplateField[]
  event_templates EventTemplate[]

  @@map("templates")
}

model Field {
  id                    String               @id @default(uuid()) @db.VarChar(36)
  identifier            String               @unique @db.VarChar(100)
  type                  FieldType
  template_id           String?              @db.VarChar(36)
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt
  template_fields       TemplateField[]
  event_template_fields EventTemplateField[]

  @@map("fields")
}

model TemplateField {
  template_id String @db.VarChar(36)
  field_id    String @db.VarChar(36)

  template Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  field    Field    @relation(fields: [field_id], references: [id], onDelete: Cascade)

  @@id([template_id, field_id])
  @@map("template_fields")
}

// ─────────────────────────────────────────────────────────
//  Events & Event Templates
// ─────────────────────────────────────────────────────────

model Event {
  id            String   @id @default(uuid()) @db.VarChar(36)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  user_id       String   @db.VarChar(36)
  start_date    DateTime
  end_date      DateTime
  event_date    DateTime
  url           String?  @db.Text
  event_type_id String   @db.VarChar(36)
  slug          String   @unique @db.VarChar(255)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event_type      EventType       @relation(fields: [event_type_id], references: [id], onDelete: Cascade)
  event_templates EventTemplate[]

  @@map("events")
}

model EventTemplate {
  id          String   @id @default(uuid()) @db.VarChar(36)
  event_id    String   @db.VarChar(36)
  template_id String   @db.VarChar(36)
  is_enabled  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  event                 Event                  @relation(fields: [event_id], references: [id], onDelete: Cascade)
  template              Template               @relation(fields: [template_id], references: [id], onDelete: Cascade)
  event_template_fields EventTemplateField[]

  @@map("event_templates")
}

model EventTemplateField {
  event_template_id String @db.VarChar(36)
  field_id          String @db.VarChar(36)
  value             String @db.Text

  // Relations
  event_template EventTemplate @relation(fields: [event_template_id], references: [id], onDelete: Cascade)
  field          Field         @relation(fields: [field_id], references: [id], onDelete: Cascade)

  @@id([event_template_id, field_id])
  @@map("event_template_fields")
}
